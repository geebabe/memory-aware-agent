# ==========================================
# LLM & API KEYS
# ==========================================
# OpenAI API Key (Bắt buộc để chạy LLM)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (Bắt buộc nếu sử dụng search_tools)
TAVILY_API_KEY=your_tavily_api_key_here

# ==========================================
# ORACLE DATABASE CONFIGURATION
# ==========================================
# Thông tin kết nối cho user nghiệp vụ (mặc định trong main.py là VECTOR)
ORACLE_DB_USER=VECTOR
ORACLE_DB_PASSWORD=VectorPwd_2025
ORACLE_DB_DSN=127.0.0.1:1521/FREEPDB1

# Thông tin Admin (Dùng để chạy setup_oracle_database lần đầu)
ORACLE_DB_ADMIN_USER=system
ORACLE_DB_ADMIN_PASSWORD=YourPassword123

# ==========================================
# AGENT CONFIGURATION (Optional)
# ==========================================
# Model mặc định sử dụng
DEFAULT_MODEL=gpt-5-mini
# Mức độ log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
